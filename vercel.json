{
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "mkdir -p .output && cp -r public/* .output/",
  "outputDirectory": ".output",
  "rewrites": [
    { "source": "/api/config", "destination": "/api/config" },
    { "source": "/api/artist/:id", "destination": "/api/artist/[id]" }
  ]
}
